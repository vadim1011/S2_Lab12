<Window x:Class="S2_Lab12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:S2_Lab12.ViewModels"
        Title="Сведения о людях" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Список людей" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding People}" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                <DataGridTextColumn Header="Пол" Binding="{Binding Gender}" Width="80"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Возраст" Binding="{Binding Age}" Width="70"/>
                <DataGridTextColumn Header="Рост" Binding="{Binding Height}" Width="70"/>
                <DataGridTextColumn Header="Вес" Binding="{Binding Weight}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" 
                Content="Найти самого молодого" 
                Command="{Binding FindYoungestCommand}"
                Padding="20,10" 
                HorizontalAlignment="Center"
                Margin="0,0,0,10"/>

        <Border Grid.Row="3" 
                Background="#F0F0F0" 
                CornerRadius="5" 
                Padding="15"
                Visibility="{Binding YoungestPerson}">

            <StackPanel>
                <TextBlock Text="САМЫЙ МОЛОДОЙ ЧЕЛОВЕК" 
                           FontWeight="Bold" 
                           FontSize="16" 
                           Foreground="DarkGreen"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding YoungestPerson, Mode=OneWay}" 
                           TextWrapping="Wrap"
                           FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
    </Window>
